<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Claude in Microsoft Office</title>
    <meta name="description" content="Claude AI assistant for Microsoft Office - Excel, Word, and PowerPoint" />
    <!-- Taskpane URL — only meaningful inside an Office host. Keep out of search results. -->
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/m-addin/icon-32.png" />
    <script src="https://appsforoffice.microsoft.com/lib/1/hosted/office.js" type="text/javascript"></script>
    <script>
      // explaination: https://stackoverflow.com/a/77867387
      delete history.pushState;
      delete history.replaceState;
    </script>
    <script type="module" crossorigin src="/m-addin/assets/index-DaxcmPIW.js"></script>
    <link rel="modulepreload" crossorigin href="/m-addin/assets/index-BbYgMePv.js">
    <link rel="stylesheet" crossorigin href="/m-addin/assets/index-tZQJTE4o.css">
  </head>
  <body>
    <!-- Hybrid Architecture: HTML wrapper + React container -->
    <div id="react-container" class="h-screen"></div>

    <script>
      // Hybrid architecture: HTML handles Office.js keyboard shortcuts to avoid React SPA conflicts
      // NOTE: This could be incorrect as the task pane might already be open, but there's no easy way to detect initial state
      let isTaskpaneVisible = false;

      Office?.onReady(() => {
        // Listen for visibility changes (handles manual close via X button)
        if (Office?.addin?.onVisibilityModeChanged) {
          Office.addin.onVisibilityModeChanged((args) => {
            isTaskpaneVisible = args.visibilityMode === "Taskpane";
          });
        }

        // Register keyboard shortcuts
        if (Office?.actions?.associate) {
          Office.actions.associate("ShowTaskpane", (event) => {
            // Call event.completed() to prevent React SPA blocking
            if (event?.completed) {
              event.completed();
            }

            // Toggle the visibility state
            isTaskpaneVisible = !isTaskpaneVisible;

            if (isTaskpaneVisible) {
              // Show task pane
              return Office.addin?.showAsTaskpane()
                .then(() => {
                  // Send message to React app about opening
                  window.postMessage({
                    type: 'KEYBOARD_SHORTCUT_TRIGGERED',
                    action: 'ShowTaskpane'
                  }, '*');
                })
                .catch((error) => {
                  return error.code;
                });
            } else {
              // Hide task pane
              return Office.addin?.hide()
                .then(() => {
                  // Send message to React app about closing
                  window.postMessage({
                    type: 'KEYBOARD_SHORTCUT_TRIGGERED',
                    action: 'HideTaskpane'
                  }, '*');
                })
                .catch((error) => {
                  return error.code;
                });
            }
          });
        }
      });
    </script>
  </body>
</html>